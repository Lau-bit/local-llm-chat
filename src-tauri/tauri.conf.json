{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local LLM Chat",
  "version": "1.0.0",
  "identifier": "com.slaur.local-llm-chat",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Local LLM Chat",
        "width": 1050,
        "height": 950,
        "minWidth": 720,
        "minHeight": 520,
        "backgroundColor": "#080807",
        "decorations": false,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
